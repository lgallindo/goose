{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Internal Marker DSL",
  "description": "Schema for repository/path internal-classification marker records.",
  "type": "object",
  "properties": {
    "marker_id": { "type": "string", "minLength": 1 },
    "scope": { "type": "string", "enum": ["repo", "path"] },
    "target": { "type": "string", "minLength": 1 },
    "classification": {
      "type": "string",
      "enum": ["internal", "non-internal", "share-candidate"]
    },
    "marked_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "performer_id": { "type": "string", "minLength": 1 },
    "rationale": { "type": "string", "minLength": 1 },
    "notes": { "type": "string" }
  },
  "required": [
    "marker_id",
    "scope",
    "target",
    "classification",
    "marked_at",
    "updated_at",
    "performer_id",
    "rationale",
    "notes"
  ],
  "additionalProperties": false
}
